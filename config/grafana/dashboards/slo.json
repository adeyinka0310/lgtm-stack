{
  "title": "SLO & Error Budget",
  "uid": "slo-dashboard",
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Availability SLI vs SLO (99.5% target)",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "slo:availability:ratio_30d * 100",
        "legendFormat": "Availability %"
      }],
      "options": {
        "minVizWidth": 75,
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 95,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 99 },
              { "color": "green", "value": 99.5 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Latency SLI (% requests under 500ms)",
      "type": "gauge",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 8 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "slo:latency:ratio_under_500ms_5m * 100",
        "legendFormat": "Under 500ms %"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 80,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 95 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Probe Uptime (30d)",
      "type": "gauge",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 8 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "slo:probe:ratio_30d * 100",
        "legendFormat": "Probe Uptime %"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 95,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 99 },
              { "color": "green", "value": 99.5 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "SLO Burn Rate (1h) — Fast Burn threshold: 0.072",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "slo:availability:burn_rate_1h",
          "legendFormat": "1h burn rate"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "slo:availability:burn_rate_6h",
          "legendFormat": "6h burn rate"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit" },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 5,
      "title": "Latency p95 over time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sli:latency:p95_5m",
          "legendFormat": "p95 latency"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sli:latency:p99_5m",
          "legendFormat": "p99 latency"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1.0 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Error Rate over time",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sli:errors:ratio_5m * 100",
        "legendFormat": "Error %"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    }
  ],
  "schemaVersion": 38
}
