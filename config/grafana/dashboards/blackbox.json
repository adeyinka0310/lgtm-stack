{
  "title": "Blackbox Exporter — Uptime & Probes",
  "uid": "blackbox-dashboard",
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Probe Success Rate",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "avg(probe_success) * 100",
        "legendFormat": "Success %"
      }],
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 99 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "HTTP Response Time p50",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "avg(probe_http_duration_seconds{phase=\"transfer\"})",
        "legendFormat": "p50 response"
      }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 3,
      "title": "SSL Certificate Expiry (days)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "(probe_ssl_earliest_cert_expiry - time()) / 86400",
        "legendFormat": "{{instance}}"
      }],
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 14 },
              { "color": "green", "value": 30 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Probe Success Timeline",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "probe_success",
        "legendFormat": "{{instance}}"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "custom": { "thresholdsStyle": { "mode": "area" } }
        }
      }
    },
    {
      "id": 5,
      "title": "HTTP Response Time by Phase",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "probe_http_duration_seconds{phase=\"resolve\"}",
          "legendFormat": "DNS {{instance}}"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "probe_http_duration_seconds{phase=\"connect\"}",
          "legendFormat": "Connect {{instance}}"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "probe_http_duration_seconds{phase=\"tls\"}",
          "legendFormat": "TLS {{instance}}"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "probe_http_duration_seconds{phase=\"transfer\"}",
          "legendFormat": "Transfer {{instance}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ],
  "schemaVersion": 38
}
